{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,               // set to false if you don't need .js files
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/app/*": ["app/*"],
      "@/components/*": ["app/components/*"],
      "@/modules/*": ["app/modules/*"],
      "@/lib/*": ["src/lib/*"],
      "@/styles/*": ["styles/*"],
      "@/public/*": ["public/*"]
    },
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    // ignore the local/CI snapshot tree that contains the stale duplicate page.tsx
    "mpathy_local_diag_*",
    "**/mpathy_local_diag_*",
    "**/mpathy_local_diag_*/**"
  ]
}
