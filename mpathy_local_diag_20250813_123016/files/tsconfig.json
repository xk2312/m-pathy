{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,               // auf false stellen, wenn keine .js-Dateien nötig sind
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/app/*": ["app/*"],
      "@/components/*": ["app/components/*"],
      "@/modules/*": ["app/modules/*"],
      "@/lib/*": ["src/lib/*"],
      "@/styles/*": ["styles/*"],
      "@/public/*": ["public/*"]
    },
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    // verhindert Prüfungen im lokal/CI erzeugten Snapshot-Baum
    "mpathy_local_diag_*",
    "**/mpathy_local_diag_*",
    "**/mpathy_local_diag_*/**"
  ]
}
