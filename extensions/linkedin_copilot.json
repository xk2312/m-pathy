{
  "id": "linkedin_copilot",
  "version": "3.0",
  "entry": "1",
  "steps": {

    "1": {
      "type": "selection",
      "language": "dynamic",
      "content": {
        "greeting": "Welcome to LinkedIn Copilot.",
        "description": "Optimize your LinkedIn profile and reach the exact audience you are targeting.",
        "options": {
          "1": "Create a post",
          "2": "Create a post campaign",
          "3": "Analyze a post",
          "4": "Optimize profile info",
          "5": "Optimize profile header",
          "6": "Write a private message",
          "7": "Reply to a private message",
          "8": "Connection request message"
        }
      },
      "next_map": {
        "1": "1.1",
        "2": "2.1",
        "3": "3.1",
        "4": "4.1",
        "5": "5.1",
        "6": "6.1",
        "7": "7.1",
        "8": "8.1"
      }
    },

    "1.1": {
      "type": "selection",
      "content": {
        "q": "Target audience age?",
        "options": {
          "1": "20-40",
          "2": "40-60",
          "3": "60+"
        }
      },
      "key": "age",
      "next_map": {
        "1": "1.2",
        "2": "1.2",
        "3": "1.2"
      }
    },

    "1.2": {
      "type": "question",
      "content": {
        "q": "Profession of the target audience (one word)"
      },
      "input": "short_text",
      "key": "job",
      "next": "1.3"
    },

    "1.3": {
      "type": "selection",
      "content": {
        "q": "Goal of the post?",
        "options": {
          "1": "Thought leadership",
          "2": "Purchase intent",
          "3": "Direct application"
        }
      },
      "key": "goal",
      "next_map": {
        "1": "1.4",
        "2": "1.4",
        "3": "1.4"
      }
    },

    "1.4": {
      "type": "selection",
      "content": {
        "q": "Content format?",
        "options": {
          "1": "Formal",
          "2": "Storytelling",
          "3": "Opinion",
          "4": "Provocative",
          "5": "Educational"
        }
      },
      "key": "format",
      "next_map": {
        "1": "1.5",
        "2": "1.5",
        "3": "1.5",
        "4": "1.5",
        "5": "1.5"
      }
    },

    "1.5": {
      "type": "selection",
      "content": {
        "q": "Tone of address?",
        "options": {
          "1": "Informal (you)",
          "2": "Formal (you)",
          "3": "Automatic"
        }
      },
      "key": "tone",
      "next_map": {
        "1": "1.6",
        "2": "1.6",
        "3": "1.6"
      }
    },

    "1.6": {
      "type": "action",
      "action": "generate_post",
      "input_keys": ["age", "job", "goal", "format", "tone"],
      "rules": {
        "cta": {
          "required": true,
          "type": "question",
          "style": "engaging"
        },
        "hashtags": {
          "count": 3,
          "position": "end"
        },
        "story": {
          "arc_required": true
        },
        "language": {
          "adaptive_tone": true,
          "backend_controlled": true
        }
      },
      "next": "end"
    },

    "end": {
      "type": "terminal"
    }

  }
}