{
  "id": "linkedin_copilot",
  "version": "2.0",
  "entry": "start",
  "archive": {},
  "steps": {
    "start": {
      "type": "selection",
      "language": "dynamic",
      "content": {
        "greeting": "Willkommen bei LinkedIn Copilot.",
        "description": "LinkedIn Copilot hilft dir dabei dein LinkedIn Profil auf Vordermann zu bringen und genau die User zu erreichen, auf die du abzielst.",
        "options_intro": "Dir stehen folgende Workflows zur Verfügung:",
        "options": [
          "1. Post entwickeln",
          "2. Postkampagne entwickeln",
          "3. Post analysieren",
          "4. Profilinfo anpassen",
          "5. Profilheader anpassen",
          "6. Private Message verfassen",
          "7. Private Message beantworten",
          "8. Vernetzungsanfrage Text"
        ],
        "cta": "Bitte gib die Nummer ein."
      },
      "next_map": {
        "1": "wps_s1",
        "2": "wpc_entry",
        "3": "wpa_entry",
        "4": "wpi_entry",
        "5": "wph_entry",
        "6": "wpmc_entry",
        "7": "wpmr_entry",
        "8": "wct_entry"
      }
    },

    "wps_s1": {
      "type": "question",
      "q": "Zielgruppe Alter?",
      "options": {
        "a": "20-40",
        "b": "40-60",
        "c": "60+"
      },
      "key": "age",
      "next": "wps_s2"
    },

    "wps_s2": {
      "type": "question",
      "q": "Beruf der Zielgruppe (1 Begriff)",
      "input": "short_text",
      "key": "job",
      "next": "wps_s3"
    },

    "wps_s3": {
      "type": "question",
      "q": "Ziel des Posts?",
      "options": {
        "a": "Meinungsführerschaft",
        "b": "Kaufbereitschaft",
        "c": "Direkte Bewerbung"
      },
      "key": "goal",
      "next": "wps_s4"
    },

    "wps_s4": {
      "type": "question",
      "q": "Format?",
      "options": {
        "a": "Sachlich",
        "b": "Storytelling",
        "c": "Meinung",
        "d": "Provokativ",
        "e": "Lehrreich"
      },
      "key": "format",
      "next": "wps_s5"
    },

    "wps_s5": {
      "type": "question",
      "q": "Ansprache?",
      "options": {
        "a": "Du",
        "b": "Sie",
        "c": "Automatisch"
      },
      "key": "tone",
      "next": "wps_final"
    },

    "wps_final": {
      "type": "action",
      "action": "generate_post",
      "input_keys": ["age", "job", "goal", "format", "tone"],
      "rules": {
        "cta": {
          "required": true,
          "type": "question",
          "style": "engaging"
        },
        "hashtags": {
          "count": 3,
          "position": "end"
        },
        "story": {
          "arc_required": true
        },
        "language": {
          "adaptive_tone": true,
          "backend_controlled": true
        }
      },
      "next": "end"
    },

    "end": {
      "type": "terminal"
    }
  }
}