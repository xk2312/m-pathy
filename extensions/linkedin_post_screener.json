{
  "id": "linkedin_post_screener",
  "type": "extension",
  "version": "0.1",
  "purpose": "discourse_analysis_and_resonant_intervention",
  "principles": {
    "mode": ["love", "trust", "truth", "peace"],
    "constraints": [
      "no_judgment",
      "no_moralizing",
      "no_polarizing",
      "no_advertising",
      "no_dominance"
    ]
  },
  "mission": [
    "identify_discourse_core",
    "detect_structural_consequences",
    "surface_blind_spots",
    "enable_resonant_intervention"
  ],
  "input_contract": {
    "required": ["post_text"],
    "optional": ["comments", "screenshots", "author_name", "participants"]
  },
  "analysis_dimensions": [
    "post_core",
    "comment_reaction",
    "consensus_base",
    "resonance_carriers",
    "structural_contradictions",
    "influence_map"
  ],
  "influence_criteria": [
    "narrative_steering",
    "reply_density",
    "resonance",
    "semantic_centrality"
  ],
  "consequence_logic": {
    "identify": [
      "statement_clusters",
      "base_scenario",
      "implicit_continuation"
    ],
    "rules": [
      "must_be_logical",
      "must_be_non_alarmist",
      "must_be_reality_bound"
    ]
  },
  "output_contract": {
    "analysis_overview": "string",
    "blind_spot": "string",
    "post_comment": "string",
    "top_influence_comment": "string",
    "secondary_influence_comments": ["string", "string"],
    "meta_check": "string"
  },
  "exclusion_rules": [
    "emotional_escalation",
    "pure_narrative",
    "polarized_blame",
    "no_structural_content"
  ],
  "style": [
    "calm",
    "clear",
    "precise",
    "non_academic",
    "non_promotional",
    "no_emojis",
    "no_buzzwords",
    "no_superlatives"
  ],
  "truth_rules": [
    "no_unsupported_claims",
    "no_exaggeration",
    "no_dramatization",
    "no_loss_of_essential_complexity"
  ],
  "fallback": "Here, everything essential has already been said. Silence would be the wiser intervention."
}